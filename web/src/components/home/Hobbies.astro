---
interface Props { lang?: 'en' | 'es'; }
const { lang = 'en' } = Astro.props;

const t = lang === 'es' ? {
  label: 'Tiempo libre',
  title: 'HOBBIES',
  items: [
    {
      title: 'Diseño web',
      caption: 'Diseñar interfaces y front-ends: tipografía, movimiento y los detalles que hacen que un sitio se sienta bien.',
      img: '/hobbies/diseno-web.png',
      alt: 'Diseño de mi sitio personal, eddn.dev',
    },
    {
      title: 'Compiladores',
      caption: 'Construir lenguajes y VMs de bytecode — como Achronyme, mi lenguaje de conocimiento cero que compila a tres máquinas.',
      img: '/hobbies/compiladores.png',
      alt: 'Achronyme — la arquitectura de tres máquinas',
    },
    {
      title: 'Programación competitiva',
      caption: 'Resolver problemas algorítmicos. LeetCode Guardian, rating 2,749 (top 0.05% global).',
      img: '/hobbies/leetcode.png',
      alt: 'Mis soluciones de LeetCode',
    },
  ],
} : {
  label: 'Off the clock',
  title: 'HOBBIES',
  items: [
    {
      title: 'Web design',
      caption: 'Crafting interfaces and front-ends: typography, motion, and the small details that make a site feel right.',
      img: '/hobbies/diseno-web.png',
      alt: 'Design of my personal site, eddn.dev',
    },
    {
      title: 'Compilers',
      caption: 'Building languages and bytecode VMs — like Achronyme, my zero-knowledge language that compiles to three machines.',
      img: '/hobbies/compiladores.png',
      alt: 'Achronyme — the three-machine architecture',
    },
    {
      title: 'Competitive programming',
      caption: 'Algorithmic problem solving. LeetCode Guardian, contest rating 2,749 (top 0.05% worldwide).',
      img: '/hobbies/leetcode.png',
      alt: 'My LeetCode solutions',
    },
  ],
};
---

<section id="hobbies" class="relative py-24 border-t border-border">
  <div class="mx-auto w-full max-w-[1200px] px-8">
    <span class="section-label block font-mono text-[0.8rem] text-accent uppercase tracking-[0.1em] mb-3" data-reveal>{t.label}</span>
    <h2 class="section-title text-[clamp(2.5rem,5vw,4rem)] mb-12" data-reveal>{t.title}</h2>

    <div class="grid grid-cols-3 max-md:grid-cols-1 gap-6">
      {t.items.map((it) => (
        <figure class="flex flex-col gap-3" data-reveal>
          <div class="aspect-[4/3] rounded-lg border border-border bg-bg-card overflow-clip">
            <img
              src={it.img}
              alt={it.alt}
              loading="lazy"
              class="w-full h-full object-cover object-left-top transition-transform duration-500 hover:scale-105"
            />
          </div>
          <figcaption>
            <h3 class="text-[1.05rem] font-bold normal-case tracking-[-0.01em]">{it.title}</h3>
            <p class="text-text-secondary text-[0.9rem] mt-1 leading-[1.5]">{it.caption}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

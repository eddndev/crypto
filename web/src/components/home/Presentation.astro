  role: 'Software Developer',
  intro: 'Developer focused on Rust, applied cryptography and WebAssembly. Currently studying Computer Systems Engineering at ESCOM, IPN.',
  location: 'Mexico City, MX',
  emailLabel: 'Email',
  socialLabel: 'Social',

---

<section class="hero relative py-32 pb-20 min-h-screen flex items-center">
  <HeroDecorations />
  <div class="dot-grid" aria-hidden="true"></div>
  {/* Photo slot intentionally omitted for now — drop an <img> here later. */}
  <div class="hero__inner relative z-1 w-full mx-auto max-w-[1200px] px-8">
    <span class="hero__label inline-block font-mono text-[0.8rem] font-medium text-accent uppercase tracking-[0.1em] mb-6">{t.role}</span>
    <h1 class="text-[clamp(3rem,8vw,6rem)] font-black leading-[0.92] tracking-[-0.04em]">
      <span class="hero__title-line block">EDUARDO</span>
      <span class="hero__title-line block">ALONSO</span>
      <span class="hero__title-line block text-accent">SÁNCHEZ</span>
    </h1>
    <div class="hero__separator w-full h-px bg-border my-12"></div>
    <div class="hero__bottom flex items-end justify-between gap-12 max-md:flex-col max-md:items-start">
      <div class="max-w-[480px] flex flex-col gap-5">
        <p class="text-[#a3a3a3] text-[1.05rem] leading-[1.7]">{t.intro}</p>
        <div class="flex flex-col gap-1 font-mono text-[0.85rem]">
          <span class="text-text-secondary uppercase tracking-[0.1em] text-[0.7rem]">{t.location}</span>
          <a href={`mailto:${email}`} class="text-text-primary hover:text-accent transition-colors duration-200 w-max">{email}</a>
        </div>
        <div class="flex items-center gap-3" aria-label={t.socialLabel}>
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
              title={s.name}
              class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-border text-text-secondary hover:text-black hover:bg-accent hover:border-accent transition-colors duration-200"
            >
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d={s.icon} /></svg>
            </a>
          ))}
        </div>
      </div>
      <div class="flex gap-4 shrink-0 max-md:flex-col max-md:w-full">
        <a href="/cv.pdf" download class="hero__cta--solid inline-flex items-center px-8 py-3.5 rounded-full text-[0.9rem] font-semibold whitespace-nowrap transition-all duration-200 bg-text-primary text-bg-primary hover:bg-accent hover:text-black max-md:w-full max-md:justify-center">{t.cv}</a>
        <a href={t.keyHref} class="inline-flex items-center px-8 py-3.5 rounded-full text-[0.9rem] font-semibold whitespace-nowrap transition-colors duration-200 text-text-secondary hover:text-text-primary max-md:w-full max-md:justify-center">{t.key}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero__label::before {
    content: '●';
    margin-right: 0.5rem;
    font-size: 0.6rem;
    vertical-align: middle;
  }

  @media (max-width: 768px) {
    .hero__inner {
      background: radial-gradient(
        ellipse at 30% 50%,
        rgba(10, 10, 10, 0.85) 0%,
        transparent 70%
      );
      padding: 2rem 1rem;
      border-radius: 1rem;
    }
  }
</style>

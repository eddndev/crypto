---

---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo">cripto</a>
    
    <input type="checkbox" id="mobile-menu-toggle" class="header__toggle-checkbox" aria-hidden="true" />
    <label for="mobile-menu-toggle" class="header__toggle-label" aria-label="Toggle menu">
      <span class="header__hamburger"></span>
    </label>

    <nav class="header__nav">
      <!-- Desktop layout remains a standard flex row, Mobile layout uses Grid -->
      <ul class="header__nav-list">
        <li class="header__nav-item">
          <a href="#practices" class="header__link">
            <span class="header__num">01</span>
            <span class="header__text">PRACTICES</span>
            <span class="header__sub">Core algorithms</span>
          </a>
        </li>
        <li class="header__nav-item">
          <a href="#about" class="header__link">
            <span class="header__num">02</span>
            <span class="header__text">ABOUT</span>
            <span class="header__sub">Project details</span>
          </a>
        </li>
        <!-- Extra item added to balance the grid visually on mobile -->
        <li class="header__nav-item header__nav-item--mobile-only">
          <a href="https://github.com/eddndev/cripto" target="_blank" rel="noopener noreferrer" class="header__link">
            <span class="header__num">03</span>
            <span class="header__text">SOURCE</span>
            <span class="header__sub">GitHub Repo</span>
          </a>
        </li>
      </ul>
      
      <div class="header__mobile-footer">
        <span>sys.status: online</span>
        <span class="header__mobile-accent">rustc 1.76.0</span>
      </div>
    </nav>
  </div>
</header>

<script>
  const checkbox = document.getElementById('mobile-menu-toggle') as HTMLInputElement;
  if (checkbox) {
    document.querySelectorAll('.header__nav .header__link').forEach((link) => {
      link.addEventListener('click', () => {
        checkbox.checked = false;
      });
    });
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .header__logo {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    position: relative;
    z-index: 102;
  }

  .header__toggle-checkbox {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    margin: 0;
    padding: 0;
    pointer-events: none;
  }

  .header__toggle-label {
    display: none;
  }

  /* Desktop Default State */
  .header__nav-list {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__link {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .header__num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
  }

  .header__text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }

  .header__link:hover .header__text {
    color: var(--text-primary);
  }

  .header__sub {
    display: none; /* Hidden on desktop */
  }

  .header__mobile-footer,
  .header__nav-item--mobile-only {
    display: none; /* Hidden on desktop */
  }

  /* =========================================
     Mobile View (Bento Grid Style)
     ========================================= */
  @media (max-width: 768px) {
    .header__toggle-label {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      cursor: pointer;
      position: relative;
      z-index: 102;
    }

    .header__hamburger,
    .header__hamburger::before,
    .header__hamburger::after {
      display: block;
      width: 24px;
      height: 2px;
      background-color: var(--text-primary);
      transition: transform 0.3s ease, opacity 0.3s ease, background-color 0.3s ease;
      position: absolute;
    }

    .header__hamburger::before {
      content: '';
      transform: translateY(-8px);
    }

    .header__hamburger::after {
      content: '';
      transform: translateY(8px);
    }

    /* Modern Grid Layout Container */
    .header__nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100dvh;
      background: rgba(10, 10, 10, 0.98);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);

      display: flex;
      flex-direction: column;
      padding: 6rem 2rem 2rem;
      overflow-y: auto;

      /* Animation state (hidden by default) */
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 101;
    }

    /* The Bento Grid */
    .header__nav-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: minmax(120px, auto);
      gap: 1rem;
      width: 100%;
      align-content: start;
    }

    /* First item spans full width to anchor the grid */
    .header__nav-item:nth-child(1) {
      grid-column: span 2;
    }

    .header__nav-item--mobile-only {
      display: block;
    }

    /* Grid Item Styling (The "Cards") */
    .header__link {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 100%;
      padding: 1.25rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 0;
      transition: background 0.3s, border-color 0.3s;
      text-decoration: none;
    }

    .header__link:active {
      background: var(--bg-card-hover);
      border-color: var(--accent-deep);
    }

    /* Typography inside mobile grid cards */
    .header__num {
      align-self: flex-end;
      font-size: 0.85rem;
      opacity: 0.5;
    }

    .header__text {
      font-size: 1.5rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--text-primary);
      margin-top: auto;
      margin-bottom: 0.25rem;
    }

    .header__sub {
      display: block;
      font-family: var(--font-ui);
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.4;
    }

    /* Tech Footer */
    .header__mobile-footer {
      display: flex;
      justify-content: space-between;
      width: 100%;
      margin-top: auto;
      padding-top: 2rem;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--text-secondary);
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .header__mobile-accent {
      color: var(--accent);
    }

    /* Checkbox interactions */
    .header__toggle-checkbox:checked ~ .header__nav {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .header__toggle-checkbox:checked ~ .header__toggle-label .header__hamburger {
      background-color: transparent;
    }

    .header__toggle-checkbox:checked ~ .header__toggle-label .header__hamburger::before {
      transform: translateY(0) rotate(45deg);
      background-color: var(--text-primary);
    }

    .header__toggle-checkbox:checked ~ .header__toggle-label .header__hamburger::after {
      transform: translateY(0) rotate(-45deg);
      background-color: var(--text-primary);
    }
  }
</style>
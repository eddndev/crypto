---

---

<header class="sticky top-0 z-100 bg-transparent backdrop-blur-[12px]">
  <div class="mx-auto w-full max-w-[1200px] px-8 flex items-center justify-between h-16">
    <a href="/" class="font-mono text-[1.1rem] font-bold text-text-primary tracking-[-0.02em] relative z-[102]">crypto</a>

    <input type="checkbox" id="mobile-menu-toggle" class="header__toggle-checkbox" aria-hidden="true" />
    <label for="mobile-menu-toggle" class="header__toggle-label" aria-label="Toggle menu">
      <span class="header__hamburger"></span>
    </label>

    <nav class="header__nav">
      <ul class="header__nav-list flex gap-10 list-none m-0 p-0">
        <li class="header__nav-item">
          <a href="#practices" class="header__link flex items-baseline gap-2 no-underline transition-colors duration-200">
            <span class="font-mono text-xs text-accent">01</span>
            <span class="header__text font-mono text-xs font-medium text-text-secondary tracking-[0.05em] transition-colors duration-200">PRACTICES</span>
            <span class="header__sub hidden">Core algorithms</span>
          </a>
        </li>
        <li class="header__nav-item">
          <a href="#about" class="header__link flex items-baseline gap-2 no-underline transition-colors duration-200">
            <span class="font-mono text-xs text-accent">02</span>
            <span class="header__text font-mono text-xs font-medium text-text-secondary tracking-[0.05em] transition-colors duration-200">ABOUT</span>
            <span class="header__sub hidden">Project details</span>
          </a>
        </li>
        <li class="header__nav-item header__nav-item--mobile-only hidden">
          <a href="https://github.com/eddndev/crypto" target="_blank" rel="noopener noreferrer" class="header__link flex items-baseline gap-2 no-underline transition-colors duration-200">
            <span class="font-mono text-xs text-accent">03</span>
            <span class="header__text font-mono text-xs font-medium text-text-secondary tracking-[0.05em] transition-colors duration-200">SOURCE</span>
            <span class="header__sub hidden">GitHub Repo</span>
          </a>
        </li>
      </ul>

      <div class="header__mobile-footer hidden">
        <span>sys.status: online</span>
        <span class="text-accent">rustc 1.76.0</span>
      </div>
    </nav>
  </div>
</header>

<script>
  const checkbox = document.getElementById('mobile-menu-toggle') as HTMLInputElement;
  if (checkbox) {
    document.querySelectorAll('.header__nav .header__link').forEach((link) => {
      link.addEventListener('click', () => {
        checkbox.checked = false;
      });
    });
  }
</script>

<style>
  /* Checkbox hidden accessibly */
  .header__toggle-checkbox {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    margin: 0;
    padding: 0;
    pointer-events: none;
  }

  .header__toggle-label {
    display: none;
  }

  .header__link:hover .header__text {
    color: var(--color-text-primary);
  }

  /* =========================================
     Mobile View (Bento Grid Style)
     ========================================= */
  @media (max-width: 768px) {
    .header__toggle-label {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      cursor: pointer;
      position: relative;
      z-index: 102;
    }

    .header__hamburger,
    .header__hamburger::before,
    .header__hamburger::after {
      display: block;
      width: 24px;
      height: 2px;
      background-color: var(--color-text-primary);
      transition: transform 0.3s ease, opacity 0.3s ease, background-color 0.3s ease;
      position: absolute;
    }

    .header__hamburger::before {
      content: '';
      transform: translateY(-8px);
    }

    .header__hamburger::after {
      content: '';
      transform: translateY(8px);
    }

    /* Full-screen nav overlay */
    .header__nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100dvh;
      background: rgba(10, 10, 10, 0.98);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      display: flex;
      flex-direction: column;
      padding: 6rem 2rem 2rem;
      overflow-y: auto;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 101;
    }

    /* Bento Grid */
    .header__nav-list {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: minmax(120px, auto);
      gap: 1rem !important;
      width: 100%;
      align-content: start;
    }

    .header__nav-item:nth-child(1) {
      grid-column: span 2;
    }

    .header__nav-item--mobile-only {
      display: block !important;
    }

    /* Grid card styling */
    .header__link {
      display: flex !important;
      flex-direction: column !important;
      justify-content: space-between !important;
      height: 100%;
      padding: 1.25rem;
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-radius: 0;
      transition: background 0.3s, border-color 0.3s;
    }

    .header__link:active {
      background: var(--color-bg-card-hover);
      border-color: var(--color-accent-deep);
    }

    /* Typography inside mobile grid cards */
    .header__link .font-mono:first-child {
      align-self: flex-end;
      font-size: 0.85rem;
      opacity: 0.5;
    }

    .header__text {
      font-size: 1.5rem !important;
      font-weight: 600 !important;
      letter-spacing: -0.02em !important;
      color: var(--color-text-primary) !important;
      margin-top: auto;
      margin-bottom: 0.25rem;
    }

    .header__sub {
      display: block !important;
      font-family: var(--font-ui);
      font-size: 0.85rem;
      color: var(--color-text-secondary);
      line-height: 1.4;
    }

    /* Tech Footer */
    .header__mobile-footer {
      display: flex !important;
      justify-content: space-between;
      width: 100%;
      margin-top: auto;
      padding-top: 2rem;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--color-text-secondary);
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* Checkbox interactions */
    .header__toggle-checkbox:checked ~ .header__nav {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .header__toggle-checkbox:checked ~ .header__toggle-label .header__hamburger {
      background-color: transparent;
    }

    .header__toggle-checkbox:checked ~ .header__toggle-label .header__hamburger::before {
      transform: translateY(0) rotate(45deg);
      background-color: var(--color-text-primary);
    }

    .header__toggle-checkbox:checked ~ .header__toggle-label .header__hamburger::after {
      transform: translateY(0) rotate(-45deg);
      background-color: var(--color-text-primary);
    }
  }
</style>

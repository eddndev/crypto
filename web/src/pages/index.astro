---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import PracticeCard from '../components/PracticeCard.astro';
import Footer from '../components/Footer.astro';

const practices = [
  {
    title: 'Steganography',
    description: 'Hide secret messages inside images using LSB encoding. Upload a file and embed hidden data invisible to the naked eye.',
    tags: ['LSB', 'images', 'encoding'],
    href: '/practices/steganography',
  },
];
---

<Base>
  <Header />
  <main class="relative overflow-hidden">
    <!-- Background blobs -->
    <div id="blob-container" class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true"></div>
    <Hero />

    <section id="practices" class="relative py-24 border-t border-border">
      <div class="mx-auto w-full max-w-[1200px] px-8">
        <div>
          <span class="section-label block font-mono text-[0.8rem] text-accent uppercase tracking-[0.1em] mb-3">What you'll build</span>
          <h2 class="section-title text-[clamp(2.5rem,5vw,4rem)] mb-12">PRACTICES</h2>
        </div>
        <div class="grid grid-cols-2 max-md:grid-cols-1 gap-px bg-border border border-border">
          {practices.map((p, i) => (
            <PracticeCard
              title={p.title}
              description={p.description}
              tags={p.tags}
              index={i + 1}
              comingSoon={!p.href}
              href={p.href}
            />
          ))}
        </div>
      </div>
    </section>

    <section id="about" class="relative py-24 pb-32 border-t border-border">
      <div class="mx-auto w-full max-w-[1200px] px-8">
        <div class="grid grid-cols-2 max-md:grid-cols-1 gap-16 max-md:gap-8 items-start">
          <div class="about__left">
            <span class="section-label block font-mono text-[0.8rem] text-accent uppercase tracking-[0.1em] mb-3">The approach</span>
            <h2 class="section-title text-[clamp(2.5rem,5vw,4rem)] mb-0">LEARN BY<br />DOING.</h2>
          </div>
          <div class="about__right flex flex-col gap-5 pt-10 max-md:pt-0">
            <p class="text-text-secondary text-[1.05rem] leading-[1.7] [&_strong]:text-text-primary [&_strong]:font-semibold">
              Each practice is implemented in <strong>Rust</strong>, compiled to
              <strong>WebAssembly</strong>, and runs entirely in your browser.
            </p>
            <p class="text-text-secondary text-[1.05rem] leading-[1.7] [&_strong]:text-text-primary [&_strong]:font-semibold">
              Upload files, transform data, and see results in real time — no
              servers involved. Understand the algorithms, see them work, and
              experiment with your own inputs.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<script>
  const blobContainer = document.getElementById('blob-container')!;
  const BLOB_SPACING = 500;
  const blobPresets = [
    { color: '#1a1a4e', size: 600, opacity: 0.40, blur: 150, x: 10 },
    { color: '#1e1b4b', size: 500, opacity: 0.30, blur: 140, x: 75 },
    { color: '#172044', size: 450, opacity: 0.35, blur: 130, x: 35 },
  ];

  function generateBlobs() {
    const totalHeight = blobContainer.parentElement!.scrollHeight;
    const needed = Math.max(2, Math.ceil(totalHeight / BLOB_SPACING));

    blobContainer.innerHTML = '';
    for (let i = 0; i < needed; i++) {
      const preset = blobPresets[i % blobPresets.length];
      const blob = document.createElement('div');
      blob.style.cssText = `
        position: absolute;
        top: ${i * BLOB_SPACING}px;
        left: ${preset.x}%;
        width: ${preset.size}px;
        height: ${preset.size}px;
        border-radius: 50%;
        background: ${preset.color};
        opacity: ${preset.opacity};
        filter: blur(${preset.blur}px);
        transform: translateX(-50%);
      `;
      blobContainer.appendChild(blob);
    }
  }

  generateBlobs();
</script>
